// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum DocumentType {
  CPF
  CNPJ

  @@map("document_type")
}

enum UserRole {
  STAFF
  ADMIN
  CLIENT

  @@map("user_role")
}

model User {
  id        Int     @id @default(autoincrement())
  firstName String  @map("first_name") @db.VarChar(100)
  lastName  String  @map("last_name") @db.VarChar(100)
  email     String  @unique @db.VarChar(255)
  phone     String? @db.VarChar(20)

  document     String       @unique @db.VarChar(18)
  documentType DocumentType @map("document_type")

  passwordHash String   @map("password_hash") @db.VarChar(255)
  role         UserRole @default(STAFF)

  lastLogin DateTime? @map("last_login") @db.Timestamptz(6)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy Int?      @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedBy Int?      @map("updated_by")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy Int?      @map("deleted_by")

  brandsCreated Brand[] @relation("BrandCreatedBy")
  brandsUpdated Brand[] @relation("BrandUpdatedBy")
  brandsDeleted Brand[] @relation("BrandDeletedBy")

  categoriesCreated Category[] @relation("CategoryCreatedBy")
  categoriesUpdated Category[] @relation("CategoryUpdatedBy")
  categoriesDeleted Category[] @relation("CategoryDeletedBy")

  productsCreated Product[] @relation("ProductCreatedBy")
  productsUpdated Product[] @relation("ProductUpdatedBy")
  productsDeleted Product[] @relation("ProductDeletedBy")

  @@map("user")
}

model Brand {
  id      Int    @id @default(autoincrement())
  name    String @db.VarChar(100)
  slug    String @unique @db.VarChar(50)
  logoUrl String @map("logo_url") @db.VarChar(255)

  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy Int       @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedBy Int       @map("updated_by")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy Int?      @map("deleted_by")

  creator User? @relation("BrandCreatedBy", fields: [createdBy], references: [id])
  updater User? @relation("BrandUpdatedBy", fields: [updatedBy], references: [id])
  deleter User? @relation("BrandDeletedBy", fields: [deletedBy], references: [id])

  products Product[] @relation("ProductBrandId")

  @@map("brand")
}

model Category {
  id      Int    @id @default(autoincrement())
  name    String @db.VarChar(100)
  slug    String @unique @db.VarChar(50)
  iconUrl String @map("icon_url") @db.VarChar(255)

  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy Int       @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedBy Int       @map("updated_by")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy Int?      @map("deleted_by")

  creator User? @relation("CategoryCreatedBy", fields: [createdBy], references: [id])
  updater User? @relation("CategoryUpdatedBy", fields: [updatedBy], references: [id])
  deleter User? @relation("CategoryDeletedBy", fields: [deletedBy], references: [id])

  productsCategory Product[] @relation("ProductCategoryId")

  @@map("category")
}

model Product {
  id             Int     @id @default(autoincrement())
  categoryId     Int     @map("category_id")
  brandId        Int     @map("brand_id")
  name           String  @db.VarChar(100)
  price          Decimal @db.Decimal(12, 2)
  description    String  @db.Text
  additionalInfo Json?
  avaliable      Boolean @db.Boolean
  imageUrl       String  @map("image_url") @db.VarChar(255)

  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy Int       @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedBy Int       @map("updated_by")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy Int?      @map("deleted_by")

  category Category @relation("ProductCategoryId", fields: [categoryId], references: [id])
  brand    Brand    @relation("ProductBrandId", fields: [brandId], references: [id])

  creator User? @relation("ProductCreatedBy", fields: [createdBy], references: [id])
  updater User? @relation("ProductUpdatedBy", fields: [updatedBy], references: [id])
  deleter User? @relation("ProductDeletedBy", fields: [deletedBy], references: [id])

  @@map("product")
}
