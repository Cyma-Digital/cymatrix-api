// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  STAFF
  CLIENT

  @@map("user_role")
}

enum DeviceStatus {
  Online
  Offline
}

model User {
  id        Int     @id @default(autoincrement())
  firstName String  @map("first_name") @db.VarChar(100)
  lastName  String  @map("last_name") @db.VarChar(100)
  email     String  @unique @db.VarChar(255)
  phone     String? @db.VarChar(20)

  passwordHash String   @map("password_hash") @db.VarChar(255)
  role         UserRole @default(STAFF)

  lastLogin DateTime? @map("last_login") @db.Timestamptz(6)

  schedulesAmount Int       @default(10) @map("schedules_amount")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy       Int?      @map("created_by")
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedBy       Int?      @map("updated_by")
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy       Int?      @map("deleted_by")

  refreshTokens    RefreshToken[]
  createdDevices   Device[]       @relation("DeviceCreator")
  templates        Template[]
  contentSchedules Schedule[]
  ownedDevices     Device[]       @relation("DeviceOwner")
  userTemplates    UserTemplate[]
  effects          Effect[]
  userEffects      UserEffect[]

  @@map("user")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int      @map("user_id")
  expiresAt DateTime @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_token")
}

model Device {
  id      Int    @id @default(autoincrement())
  name    String @db.VarChar(255)
  code    String @unique @db.VarChar(255)
  ownerId Int?   @map("owner_id")

  status   DeviceStatus @default(Offline)
  type     String       @default("matrix")
  lastSeen DateTime?    @map("last_seen") @db.Timestamptz(6)
  metrics  Json?
  dataJson Json?        @map("data_json")

  address         String? @db.VarChar(255)
  city            String? @db.VarChar(100)
  state           String? @db.VarChar(2)
  zipCode         String? @map("zip_code") @db.VarChar(20)
  deviceOverrides Json?   @map("device_overrides")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy Int       @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedBy Int?      @map("updated_by")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy Int?      @map("deleted_by")

  creator                User                   @relation("DeviceCreator", fields: [createdBy], references: [id])
  owner                  User?                  @relation("DeviceOwner", fields: [ownerId], references: [id])
  contentSchedules       Schedule[]
  deviceMetricsHistories DeviceMetricsHistory[]

  @@map("device")
}

model Template {
  id             Int     @id @default(autoincrement())
  name           String  @db.VarChar(100)
  description    String? @db.VarChar(255)
  preset         Json
  editableFields Json    @map("editable_fields")
  active         Boolean @default(true)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy Int       @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedBy Int?      @map("updated_by")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy Int?      @map("deleted_by")

  creator          User           @relation(fields: [createdBy], references: [id])
  contentSchedules Schedule[]
  userTemplate     UserTemplate[]

  @@map("template")
}

model Schedule {
  id           Int  @id @default(autoincrement())
  deviceId     Int  @map("device_id")
  templateId   Int  @map("template_id")
  customFields Json @map("custom_fields")

  weekdays    Json
  startTime   String?   @map("start_time") @db.VarChar(5)
  endTime     String?   @map("end_time") @db.VarChar(5)
  startDate   DateTime? @map("start_date") @db.Timestamptz(6)
  endDate     DateTime? @map("end_date") @db.Timestamptz(6)
  active      Boolean   @default(true)
  durationSec Int?      @map("durantion_sec")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy Int       @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedBy Int?      @map("updated_by")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy Int?      @map("deleted_by")

  device         Device           @relation(fields: [deviceId], references: [id])
  template       Template         @relation(fields: [templateId], references: [id])
  creator        User             @relation(fields: [createdBy], references: [id])
  scheduleEffect ScheduleEffect[]

  @@map("schedule")
}

model UserTemplate {
  id         Int @id @default(autoincrement())
  userId     Int @map("user_id")
  templateId Int @map("template_id")

  user     User     @relation(fields: [userId], references: [id])
  template Template @relation(fields: [templateId], references: [id])

  @@unique([userId, templateId])
  @@map("user_template")
}

model Effect {
  id             Int     @id @default(autoincrement())
  name           String  @db.VarChar(100)
  description    String? @db.VarChar(255)
  preset         Json
  editableFields Json    @map("editable_fields")
  active         Boolean @default(true)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy Int       @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedBy Int?      @map("updated_by")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy Int?      @map("deleted_by")

  creator        User             @relation(fields: [createdBy], references: [id])
  userEffect     UserEffect[]
  scheduleEffect ScheduleEffect[]

  @@map("effect")
}

model UserEffect {
  id       Int @id @default(autoincrement())
  userId   Int @map("user_id")
  effectId Int @map("effect_id")

  user   User   @relation(fields: [userId], references: [id])
  effect Effect @relation(fields: [effectId], references: [id])

  @@unique([userId, effectId])
  @@map("user_effect")
}

model ScheduleEffect {
  id         Int @id @default(autoincrement())
  effectId   Int @map("effect_id")
  scheduleId Int @map("schedule_id")

  effect   Effect   @relation(fields: [effectId], references: [id])
  schedule Schedule @relation(fields: [scheduleId], references: [id])

  @@unique([effectId, scheduleId])
  @@map("schedule_effect")
}

model DeviceMetricsHistory {
  id        Int      @id @default(autoincrement())
  deviceId  Int
  data      Json
  createdAt DateTime @db.Timestamptz(6)

  device Device @relation(fields: [deviceId], references: [id])

  @@index([deviceId, createdAt])
  @@index([createdAt])
  @@map("device_metrics_history")
}
