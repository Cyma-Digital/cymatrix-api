{
  "name": "abdou-portal-api",
  "version": "1.0.0",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "build": "prisma generate &&  prisma migrate deploy && tsup",
    "commitlint": "commitlint",
    "commit": "cz",
    "commit:all": "git add -A && cz",
    "lint:eslint": "eslint .",
    "lint:prettier:check": "prettier --check . ",
    "lint:prettier:fix": "prettier --write .",
    "lint:prettier:check:debug": "prettier --check . --log-level debug",
    "services:database:up": "docker compose -f infra/compose.yaml up -d",
    "services:database:stop": "docker compose -f infra/compose.yaml stop",
    "services:database:down": "docker compose -f infra/compose.yaml down",
    "prisma:migrations:create": "prisma migrate dev --create-only",
    "prisma:migrations:apply": "prisma migrate dev",
    "prisma:migrations:status": "prisma migrate status",
    "prisma:migrations:deploy": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "prisma:seed": "tsx src/seed/index.ts",
    "runner:orchestrator:setup": "npx tsx tests/helpers/orchestrator.runner.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky",
    "test:coverage": "vitest run --coverage",
    "generate:users": "tsx scripts/generate.user.payloads.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "argon2": "^0.44.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "pg": "^8.17.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@eslint/js": "^9.39.2",
    "@faker-js/faker": "^10.2.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.0.9",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.0",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.0",
    "prisma": "^7.2.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.1",
    "vite-tsconfig-paths": "^6.0.5",
    "vitest": "^4.0.18"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
